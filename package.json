{
  "name": "pact-broker-workers",
  "version": "1.0.0",
  "description": "A lightweight Pact Broker running on Cloudflare Workers with Durable Objects",
  "type": "module",
  "scripts": {
    "predev": "node scripts/render-wrangler-dev.mjs",
    "dev": "wrangler dev",
    "predeploy": "node scripts/render-wrangler-dev.mjs",
    "deploy": "wrangler deploy",
    "test": "vitest",
    "test:run": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit",
    "type-check": "tsc --noEmit",
    "lint": "oxlint --deny-warnings src",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "cf-typegen": "wrangler types",
    "terraform:init": "terraform -chdir=infra init -backend-config=backend.hcl",
    "terraform:plan": "terraform -chdir=infra plan",
    "terraform:apply": "terraform -chdir=infra apply"
  },
  "keywords": [
    "pact",
    "pact-broker",
    "contract-testing",
    "cloudflare-workers",
    "durable-objects",
    "edge"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/bison-digital/pact-broker-workers.git"
  },
  "license": "MIT",
  "dependencies": {
    "drizzle-orm": "^0.38.0",
    "hono": "^4.6.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.8.0",
    "@cloudflare/workers-types": "^4.20241205.0",
    "@types/node": "^22.10.0",
    "drizzle-kit": "^0.31.0",
    "oxlint": "^0.15.0",
    "prettier": "^3.4.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.9",
    "wrangler": "^3.93.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
