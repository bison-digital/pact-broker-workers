{
  "name": "pact-broker-workers",
  "version": "1.0.0",
  "description": "A lightweight Pact Broker running on Cloudflare Workers with Durable Objects",
  "type": "module",
  "packageManager": "pnpm@10.18.2",
  "scripts": {
    "predev": "node scripts/render-wrangler-dev.mjs",
    "dev": "wrangler dev",
    "predeploy": "node scripts/render-wrangler-dev.mjs",
    "deploy": "wrangler deploy",
    "pretest": "node scripts/render-wrangler-dev.mjs",
    "test": "vitest",
    "pretest:run": "node scripts/render-wrangler-dev.mjs",
    "test:run": "vitest run",
    "typecheck": "tsgo --noEmit",
    "type-check": "tsgo --noEmit",
    "lint": "oxlint --deny-warnings src test",
    "lint:fix": "oxlint --fix src test",
    "format": "oxfmt src test",
    "format:check": "oxfmt --check src test",
    "cf-typegen": "wrangler types",
    "terraform:init": "terraform -chdir=infra init -backend-config=backend.hcl",
    "terraform:plan": "terraform -chdir=infra plan",
    "terraform:apply": "terraform -chdir=infra apply"
  },
  "keywords": [
    "pact",
    "pact-broker",
    "contract-testing",
    "cloudflare-workers",
    "durable-objects",
    "edge"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/bison-digital/pact-broker-workers.git"
  },
  "license": "MIT",
  "dependencies": {
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.16",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.15.2",
    "@cloudflare/workers-types": "^4.20260504.1",
    "@types/node": "^22.10.0",
    "@typescript/native-preview": "7.0.0-dev.20260327.2",
    "drizzle-kit": "^0.31.10",
    "oxfmt": "^0.47.0",
    "oxlint": "^1.62.0",
    "typescript": "^5.9.3",
    "vitest": "^2.1.9",
    "wrangler": "^3.93.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
